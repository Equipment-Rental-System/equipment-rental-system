{
  "expo": {
    "name": "스마트 학과 기자재 대여 관리기",
    "slug": "smart-equipment-rental",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.smartequipmentrental",
      "infoPlist": {
        "NSCameraUsageDescription": "QR 코드를 스캔하려면 카메라 접근이 필요합니다.",
        "NSPhotoLibraryUsageDescription": "학생증 이미지를 업로드하려면 사진 보관함 접근이 필요합니다."
      }
    },
    "android": {
      "package": "com.example.smartequipmentrental",
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "QR 코드를 스캔하려면 카메라 접근이 필요합니다."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "학생증 이미지를 업로드하려면 사진 접근이 필요합니다."
        }
      ]
    ]
  }
}

